managed implementation in class zbp_i_ai_incident unique;

define behavior for ZI_AI_INCIDENT
persistent table zai_incident
lock master
authorization master ( instance )

{

  create;
  update;
  delete;

  determination SetInitialValues on modify { create; }

  field ( readonly, numbering : managed ) incident_id;
  field ( readonly ) created_at,
  created_by;
}